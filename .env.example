# Outlook / Microsoft 365 inloggegevens
# Persoonlijk account (outlook.com / hotmail.com / live.com): gebruik je gewone wachtwoord
# Zakelijk M365-account: gebruik je gewone wachtwoord (SMTP AUTH moet aan staan in admin center)
OUTLOOK_USER=jouw.email@outlook.com
OUTLOOK_PASSWORD=jouw-wachtwoord

# Waar de wekelijkse rapportage naartoe gestuurd moet worden
RECIPIENT_EMAIL=ontvanger@example.com
